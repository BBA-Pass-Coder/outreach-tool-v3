# Required ----------------------------------------------------------
# Postgres connection string. Railway provides this automatically when
# you attach a Postgres plugin: copy it from Variables -> DATABASE_URL.
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Set to "true" if your Postgres is external (Supabase, Neon, etc.).
# Leave unset/false for Railway's internal Postgres plugin.
PGSSL=false

# Apify token (from https://console.apify.com/account/integrations)
APIFY_TOKEN=apify_api_xxx

# Anthropic API key (from https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxx

# Auth --------------------------------------------------------------
# HTTP Basic Auth credentials. If BASIC_AUTH_PASS is empty the server runs
# without auth and prints a warning on boot. Set BOTH for any deployment
# you do not want the open internet to be able to hit.
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=

# Optional ----------------------------------------------------------
PORT=3000

# Apify actor used for bio scraping. Default works for most TikTok bio jobs.
APIFY_ACTOR=clockworks/tiktok-profile-scraper

# Optional Apify proxy country (e.g. US, IN). Omit unless you have a reason
# to force a specific proxy region. The old code passed the literal string
# "None" which Apify interpreted incorrectly; this is the fix.
# APIFY_PROXY_COUNTRY=

# Claude model used for matching. Sonnet is the sweet spot for cost / accuracy.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Tuning ------------------------------------------------------------
SCRAPE_BATCH_SIZE=50         # handles per Apify call
EVAL_BATCH_SIZE=20           # creators per Claude call
SCRAPE_POLL_MS=5000          # scraper poll interval (ms)
EVAL_POLL_MS=4000            # evaluator poll interval (ms)
BIO_REFRESH_DAYS=30          # skip re-scraping if bio is newer than this (0 = always re-scrape)

# Per-row retry ceiling. Transient Apify / Anthropic errors are retried up
# to this many times before the row is marked permanently failed.
SCRAPE_MAX_ATTEMPTS=3
EVAL_MAX_ATTEMPTS=3

# How long a claimed row can sit in_flight before the reaper resets it back
# to pending. Protects against worker crashes mid-batch.
SCRAPE_CLAIM_TIMEOUT_MS=600000
EVAL_CLAIM_TIMEOUT_MS=600000

# Anthropic call timeout / max output. Bump max_tokens up if you use a
# rubric with many dimensions and 20-creator batches start truncating.
ANTHROPIC_MAX_TOKENS=4096

# Apify run timeout in seconds
APIFY_TIMEOUT_S=300

# If you want to keep the full raw Apify item per creator (old behaviour),
# set this to true. Default trims to a curated subset to keep the DB small.
RAW_PROFILE_FULL=false

# Linktree worker (two-hop bio_link -> contacts) ---------------------
LINKTREE_ENABLED=true
LINKTREE_POLL_MS=8000
LINKTREE_BATCH_SIZE=10
LINKTREE_MAX_ATTEMPTS=3
LINKTREE_TIMEOUT_MS=15000
LINKTREE_MAX_BYTES=1048576
LINKTREE_MIN_INTERVAL_MS=1500
# Extra hosts beyond the built-in allowlist, comma-separated:
# LINKTREE_EXTRA_HOSTS=mybrand.com,clinic.com
LINKTREE_USER_AGENT=Mozilla/5.0 (compatible; CreatorScraperBot/1.0; +internal-tool)

# Rate limiting -----------------------------------------------------
RATE_LIMIT_READ_PER_MIN=120
RATE_LIMIT_JOBS_PER_HOUR=10

# CSV export safety ceiling
CSV_MAX_ROWS=1000000

# Vision worker (Playwright screenshot + vision model) -----------------------
# Per-job opt-in via the "enable_visual" checkbox on the job form.
VISION_ENABLED=true
# Provider: openai (default, cheap) or anthropic
VISION_PROVIDER=openai
# Required if VISION_PROVIDER=openai (and recommended even if not, for fallback)
OPENAI_API_KEY=
# OpenAI vision model + detail. gpt-4o-mini at "low" detail is ~$0.0004/image.
VISION_OPENAI_MODEL=gpt-4o-mini
VISION_OPENAI_DETAIL=low
# Anthropic vision model (used when VISION_PROVIDER=anthropic)
VISION_ANTHROPIC_MODEL=claude-sonnet-4-6
# How many additional viewport screenshots to capture after the initial one.
# Default 1 = two screenshots total (initial view + one scroll down).
VISION_SCROLL_COUNT=1
# Browser lifecycle / anti-detection knobs (ported from verifier.py)
VISION_RECYCLE_EVERY=15
VISION_DELAY_MIN_MS=3000
VISION_DELAY_MAX_MS=8000
VISION_NAV_TIMEOUT_MS=30000
VISION_POLL_MS=5000
VISION_MAX_ATTEMPTS=3
VISION_CLAIM_TIMEOUT_MS=600000
VISION_SCREENSHOT_DIR=/tmp/creator-screenshots

# Transcripts worker (Apify videos + OpenAI Whisper) -------------------------
# Per-job opt-in via the "enable_transcripts" checkbox on the job form.
TRANSCRIPTS_ENABLED=true
# Apify actor for fetching a creator's recent videos. Default is the free one;
# swap to a paid actor if you need higher reliability or richer metadata.
APIFY_VIDEOS_ACTOR=clockworks/free-tiktok-scraper
# Whisper API model. whisper-1 is the only general option today.
WHISPER_MODEL=whisper-1
# Audio cap per video sent to Whisper. Caps cost and stays under 25MB limit.
AUDIO_MAX_SECONDS=60
# Cached videos refresh window. Set to 0 to always re-fetch.
VIDEO_REFRESH_DAYS=30
TRANSCRIPT_POLL_MS=6000
TRANSCRIPT_MAX_ATTEMPTS=3
TRANSCRIPT_CLAIM_TIMEOUT_MS=900000
TRANSCRIPT_TMP_DIR=/tmp/creator-audio

# Outreach pipeline (v1.5) ---------------------------------------------------
# Three workers run alongside the rest: a generator that personalizes drafts
# via Claude, a sender that pushes approved emails over SMTP, and an IMAP
# listener that watches Mayank's inbox for replies and bounces. All three can
# be individually disabled.
#
# Email generator pulls each creator's bio + recent transcripts + match cues
# from the DB, hands them to Claude with the campaign template's personalization
# instructions, and fills the [PERSONALIZED] placeholder. Uses ANTHROPIC_API_KEY
# already set above. Cost is ~$0.001 per generated email at current Sonnet prices.
EMAIL_GENERATOR_ENABLED=true
EMAIL_GEN_POLL_MS=4000
EMAIL_GEN_MAX_ATTEMPTS=3
# How many recent transcripts to feed Claude per creator (more = richer
# personalization but more tokens spent).
EMAIL_GEN_MAX_TRANSCRIPTS=3

# Sender worker pushes approved emails through SMTP using each sender's
# configured App Password. Daily caps are enforced per sender row in the DB,
# not via env. Threading via In-Reply-To headers is automatic for follow-ups.
EMAIL_SENDER_ENABLED=true
EMAIL_SEND_POLL_MS=5000
EMAIL_SEND_MAX_RETRIES=3

# IMAP listener polls each active sender's Gmail inbox for new messages.
# Detects replies (In-Reply-To header matches a sent Message-ID) and bounces
# (sender = mailer-daemon, or bounce-y subject + Message-ID in the body).
# Both auto-pause the creator's sequence per your campaign settings. Make sure
# IMAP is enabled in the Gmail account settings (default on for Workspace).
IMAP_LISTENER_ENABLED=true
IMAP_POLL_MS=60000
IMAP_FETCH_LIMIT=100
